// Table users { ... existant ... }

Table library_entry {                      // bibliothèque perso ("suivis")
  user_id    integer [ref: > users.id]
  novel_id   integer [ref: > novel.id]
  status     enum                          // PLAN_TO_READ · READING · COMPLETED · PAUSED
